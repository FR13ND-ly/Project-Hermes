  "query": "SELECT u.id as user_id, u.email, u.username, r.name as role_name\n         FROM workspace_members wm\n         JOIN users u ON wm.user_id = u.id\n         JOIN roles r ON wm.role_id = r.id\n         WHERE wm.workspace_id = $1\n         ORDER BY u.email ASC",
