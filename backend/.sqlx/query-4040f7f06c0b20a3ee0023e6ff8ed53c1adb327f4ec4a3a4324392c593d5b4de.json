{
  "db_name": "PostgreSQL",
  "query": "SELECT ai.container_name, ai.internal_port, ai.assigned_domain, a.id as app_id, a.project_id, a.workspace_id, ai.cpu_limit, ai.memory_limit_mb, u.github_token, a.start_command, a.git_subpath, a.git_credential_id\n         FROM app_instances ai\n         JOIN apps a ON ai.app_id = a.id\n         JOIN workspaces w ON a.workspace_id = w.id\n         JOIN users u ON w.created_by = u.id\n         WHERE ai.id = $1",
