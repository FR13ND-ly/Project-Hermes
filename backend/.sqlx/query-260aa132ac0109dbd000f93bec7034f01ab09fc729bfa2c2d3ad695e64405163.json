  "db_name": "PostgreSQL",
  "query": "SELECT ab.id, ab.app_id, ab.app_instance_id, ab.status, ab.phase, ab.failure_reason, ab.failure_category, ab.created_at, ai.branch_name, ab.commit_message, ab.commit_sha, ab.duration_sec, ab.image_tag, ai.current_image_tag\n         FROM app_builds ab\n         JOIN app_instances ai ON ab.app_instance_id = ai.id\n         WHERE ab.app_id = $1\n         ORDER BY ab.created_at DESC\n         LIMIT $2 OFFSET $3",
