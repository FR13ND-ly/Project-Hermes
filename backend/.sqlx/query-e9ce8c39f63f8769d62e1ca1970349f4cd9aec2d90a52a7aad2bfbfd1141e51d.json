{
  "db_name": "PostgreSQL",
  "query": "SELECT ab.app_instance_id, ai.branch_name, a.git_repository, a.build_command, ai.container_name, a.workspace_id\n         FROM app_builds ab\n         JOIN app_instances ai ON ab.app_instance_id = ai.id\n         JOIN apps a ON ab.app_id = a.id\n         WHERE ab.id = $1 AND ab.app_id = $2 AND a.workspace_id = $3",
