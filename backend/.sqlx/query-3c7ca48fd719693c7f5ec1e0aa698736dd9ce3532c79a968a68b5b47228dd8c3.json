  "query": "SELECT ai.id, ai.container_name, ai.internal_port, ai.health_check_path, ai.status as \"status: AppStatus\", a.workspace_id\n                 FROM app_instances ai\n                 JOIN apps a ON ai.app_id = a.id\n                 WHERE ai.status = 'running' OR ai.status = 'failed' OR ai.status = 'crashed'",
