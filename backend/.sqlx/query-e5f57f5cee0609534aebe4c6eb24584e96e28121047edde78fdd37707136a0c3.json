{
  "db_name": "PostgreSQL",
  "query": "SELECT il.id, il.workspace_id, il.app_instance_id, il.incident_type, il.message, il.resolved_at, il.created_at, ai.container_name as instance_name\n         FROM app_incident_logs il\n         JOIN app_instances ai ON il.app_instance_id = ai.id\n         JOIN apps a ON ai.app_id = a.id\n         WHERE a.project_id = $1 AND il.workspace_id = $2\n         ORDER BY il.created_at DESC\n         LIMIT $3 OFFSET $4",
