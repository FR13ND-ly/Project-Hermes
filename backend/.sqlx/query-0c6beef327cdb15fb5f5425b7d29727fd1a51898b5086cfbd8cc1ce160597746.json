{
  "db_name": "PostgreSQL",
  "query": "SELECT v.id, v.app_id, a.name AS app_name, v.name, v.container_path, v.host_path\n         FROM app_volumes v\n         JOIN apps a ON v.app_id = a.id\n         WHERE a.project_id = $1 AND a.workspace_id = $2\n         ORDER BY a.name ASC, v.name ASC",
