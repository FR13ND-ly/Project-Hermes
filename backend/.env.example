# ─────────────────────────────────────────────────────────────────────────────
# Hermes backend configuration. Copy to `.env` and fill in real values.
# Variables marked (REQUIRED) must be set or the server refuses to start.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# (REQUIRED) Postgres connection string.
DATABASE_URL=postgres://hermes:hermes@localhost:5432/hermes
# HTTP port the API binds to (default 3000).
PORT=8000

# ── Secrets (REQUIRED — validated at startup, no insecure fallbacks) ──────────
# HS256 signing secret for session JWTs. Must be >= 32 chars. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Symmetric key for AES-256-GCM encryption of stored env values. Must be EXACTLY
# 32 bytes. Generate with:  openssl rand -hex 16   (32 hex chars = 32 bytes)
HERMES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# JWT lifetimes in seconds (optional; defaults shown).
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ── First-boot platform root account ─────────────────────────────────────────
# (REQUIRED on first boot) Password for the bootstrapped super-admin.
HERMES_ROOT_PASSWORD=change-me
HERMES_ROOT_EMAIL=admin@hermes.platform
HERMES_ROOT_USERNAME=root

# ── Networking / CORS ────────────────────────────────────────────────────────
# Comma-separated browser origin allowlist. Leave unset or "*" to allow any
# origin (dev only). In production set the real frontend origin(s).
CORS_ALLOWED_ORIGINS=*
# Base domain apps are exposed under, and the ingress IP / SSL issuer.
HERMES_BASE_DOMAIN=hermes.local
HERMES_INGRESS_IP=
HERMES_SSL_ISSUER=letsencrypt-prod

# ── Observability ────────────────────────────────────────────────────────────
# "json" for structured logs (recommended in prod), anything else = pretty.
HERMES_LOG_FORMAT=json
# If set, GET /metrics requires `Authorization: Bearer <METRICS_TOKEN>`.
METRICS_TOKEN=
# Prometheus base URL used to read app telemetry.
HERMES_PROMETHEUS_URL=http://localhost:9090
# OpenTelemetry OTLP/http endpoint + service name (optional).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=hermes-backend
# Health-check failure threshold and memory-alert ratio.
HERMES_HEALTH_FAILURE_THRESHOLD=3
HERMES_MEM_ALERT_RATIO=0.9

# ── Builds / registry ────────────────────────────────────────────────────────
HERMES_MAX_CONCURRENT_BUILDS=2
HERMES_REGISTRY_URL=
HERMES_REGISTRY_USER=
HERMES_REGISTRY_PASSWORD=
HERMES_TRIVY_ENABLED=false
HERMES_GITHUB_WEBHOOK_SECRET=

# ── Garbage collection (hourly leader-gated worker; reclaims registry/DB/pods) ──
# HERMES_GC_INTERVAL_SECS=3600      # how often the GC pass runs (min 60)
# HERMES_BUILD_RETENTION=20         # newest builds kept per app (older pruned + image)
# HERMES_JOB_RETENTION_DAYS=7       # finished `jobs` rows older than this are deleted
# HERMES_CACHE_RETENTION_DAYS=3     # Kaniko build-cache tags older than this are pruned
# HERMES_REGISTRY_BLOB_GC=on        # set 'off' to skip the registry garbage-collect Job
# HERMES_REGISTRY_API_URL=          # registry API base for GC (defaults to HERMES_REGISTRY_URL)

# ── Storage (S3-compatible) ──────────────────────────────────────────────────
# "native" (built-in) or "s3".
STORAGE_PROVIDER=native
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Cloudflare (optional, platform-level fallback) ───────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Default workspace quotas (0 = unlimited) ─────────────────────────────────
WORKSPACE_MAX_MEMORY_MB=0
WORKSPACE_MAX_STORAGE_GB=0
